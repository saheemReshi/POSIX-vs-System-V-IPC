# Default configuration for the POSIX vs SysV IPC benchmark suite.

# Repetitions per configuration.  20+ recommended for paper-grade statistics
# (bootstrap CIs, Mann-Whitney, Welch t).  Drop to 3 only for smoke tests.
RUNS=20
PERF_RUNS=5
STRACE_RUNS=1

# Iteration / message counts.
PP_ITERS=50000
TP_MSGS=200000
SC_K=10000

# Test matrices.
PINGPONG_SIZES="8 64 256 1024 4096 8192"
THROUGHPUT_SIZES="8 64 256 1024 4096 8192"
THROUGHPUT_DEPTHS="1 8 32 128 512"
SCALABILITY_SIZES="64 256 1024"
FANIN_N="1 2 4 8 16"
PAIRS_N="1 2 4 8"

# Quick-mode overrides (used with --quick).
QUICK_RUNS=3
QUICK_PP_ITERS=5000
QUICK_TP_MSGS=20000
QUICK_SC_K=1000

# Run-order randomisation.  When enabled, all (benchmark, config, run_id)
# tuples within a stack are shuffled before execution to decouple system
# drift from mechanism comparison.  Set RANDOMIZE=0 to keep deterministic
# order (useful for debugging individual binaries).
RANDOMIZE=1
