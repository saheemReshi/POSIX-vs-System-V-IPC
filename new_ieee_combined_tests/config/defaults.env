# Default configuration for the lightweight POSIX vs SysV benchmark suite.

# Repetitions per configuration.
RUNS=1
PERF_RUNS=3   # or 5 max
STRACE_RUNS=1

# Iteration/message counts.
PP_ITERS=50000
TP_MSGS=200000
SC_K=10000

# Test matrices.
PINGPONG_SIZES="8 64 256 1024 4096 8192"
THROUGHPUT_SIZES="8 64 256 1024 4096 8192"
THROUGHPUT_DEPTHS="1 8 32 128 512"
SCALABILITY_SIZES="64 256 1024"
FANIN_N="1 2 4 8 16"
PAIRS_N="1 2 4 8"

# Quick mode overrides (used with --quick).
QUICK_RUNS=3
QUICK_PP_ITERS=5000
QUICK_TP_MSGS=20000
QUICK_SC_K=1000
